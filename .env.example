# PromptVault Environment Variables
# Copy this file to .env and fill in the values.

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://promptvault:promptvault@db:5432/promptvault
POSTGRES_USER=promptvault
POSTGRES_PASSWORD=promptvault
POSTGRES_DB=promptvault

# ─── Application ────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]

# ─── Auth (future) ──────────────────────────────────────────
JWT_SECRET=change-me-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# ─── Cloudinary (future) ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Stripe (future) ────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Frontend (Next.js public vars) ─────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
